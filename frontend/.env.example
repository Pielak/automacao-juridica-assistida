# ============================================================
# Automação Jurídica Assistida — Variáveis de Ambiente (Frontend)
# ============================================================
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis prefixadas com VITE_ são expostas ao código cliente.
# NUNCA coloque segredos aqui — tudo é visível no bundle final.
# ============================================================

# ------------------------------------------------------------
# API Backend
# ------------------------------------------------------------
# URL base da API REST (FastAPI). Em desenvolvimento local,
# normalmente aponta para o servidor FastAPI rodando na porta 8000.
VITE_API_URL=http://localhost:8000/api/v1

# Timeout padrão para requisições HTTP (em milissegundos)
VITE_API_TIMEOUT=30000

# ------------------------------------------------------------
# Aplicação
# ------------------------------------------------------------
# Título exibido na aba do navegador e em componentes de layout
VITE_APP_TITLE=Automação Jurídica Assistida

# Descrição curta da aplicação (meta tags, SEO, acessibilidade)
VITE_APP_DESCRIPTION=Plataforma de automação e análise jurídica assistida por IA

# Versão da aplicação (exibida no rodapé / painel de admin)
VITE_APP_VERSION=0.1.0

# Ambiente de execução (development | staging | production)
VITE_APP_ENV=development

# ------------------------------------------------------------
# Autenticação
# ------------------------------------------------------------
# Tempo de inatividade (em minutos) antes de encerrar a sessão
VITE_SESSION_TIMEOUT_MINUTES=30

# Habilitar MFA (TOTP) na interface de login (true | false)
VITE_MFA_ENABLED=true

# ------------------------------------------------------------
# Upload de Arquivos
# ------------------------------------------------------------
# Tamanho máximo de upload em bytes (padrão: 20 MB)
VITE_MAX_UPLOAD_SIZE=20971520

# Tipos MIME permitidos para upload (separados por vírgula)
VITE_ALLOWED_FILE_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ------------------------------------------------------------
# Observabilidade / Debug
# ------------------------------------------------------------
# Habilitar logs detalhados no console do navegador (true | false)
VITE_DEBUG=false

# URL do serviço de rastreamento de erros (ex.: Sentry DSN)
# Deixe vazio para desabilitar em desenvolvimento
VITE_SENTRY_DSN=

# ------------------------------------------------------------
# Feature Flags
# ------------------------------------------------------------
# Habilitar módulo de chat com IA (integração Anthropic Claude)
VITE_FEATURE_AI_CHAT=true

# Habilitar busca semântica de documentos
VITE_FEATURE_SEMANTIC_SEARCH=false
