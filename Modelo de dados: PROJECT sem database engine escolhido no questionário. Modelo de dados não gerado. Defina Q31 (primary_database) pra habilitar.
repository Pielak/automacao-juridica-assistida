# src/services/database_service.py
"""
Módulo de serviço de banco de dados para o sistema jurídico.
Gerencia conexão SQLite criptografada com SQLCipher, migrações e operações CRUD.

Conforme ISO 27001: Controle A.8.2.1 - Classificação da informação
Conforme LGPD: Art. 46 - Segurança e sigilo dos dados
"""

import logging
import os
import sqlite3
from contextlib import contextmanager
from datetime import datetime
from pathlib import Path
from typing import Any, Dict, Generator, List, Optional, Tuple
import json

from cryptography.hazmat.primitives.kdf.pbkdf2 import PBKDF2HMAC
from cryptography.hazmat.primitives import hashes
from cryptography.hazmat.backends import default_backend
import base64

# Configuração de logging estruturado
logger = logging.getLogger(__name__)

# Constantes de segurança
PBKDF2_ITERATIONS = 100000
KEY_LENGTH = 32  # 256 bits para AES-256
SALT_LENGTH = 16
WAL_MODE = "WAL"
CIPHER_CONFIG = {
    "cipher": "aes-256-cbc",
    "kdf_iter": str(PBKDF2_ITERATIONS),
    "cipher_page_size": "4096",
    "hmac_algorithm": "SHA512",
    "kdf_algorithm": "PBKDF2_HMAC_SHA512"
}


class DatabaseError(Exception):
    """Exceção base para erros de banco de dados."""
    pass


class DatabaseConnectionError(DatabaseError):
    """Erro de conexão com o banco de dados."""
    pass


class DatabaseMigrationError(DatabaseError):
    """Erro durante migração de schema."""
    pass


class DatabaseService:
    """
    Serviço de banco de dados com SQLite criptografado via SQLCipher.
    
    Implementa:
    - Conexão segura com criptografia AES-256-CBC
    - Gerenciamento de migrações versionadas
    - Operações CRUD com logging de auditoria
    - Conexão thread-safe com WAL mode
    """
    
    def __init__(
        self,
        db_path: Path,
        encryption_key: str,
        enable_audit: bool = True,
        wal_mode: bool = True
    ):
        """
        Inicializa o serviço de banco de dados.
        
        Args:
            db_path: Caminho para o arquivo do banco de dados
            encryption_key: Chave de criptografia (derivada da senha do usuário)
            enable_audit: Habilita logging de auditoria para operações
            wal_mode: Habilita WAL mode para melhor concorrência
            
        Raises:
            DatabaseConnectionError: Se não for possível estabelecer conexão
        """
        self.db_path = db_path
        self.encryption_key = encryption_key
        self.enable_audit = enable_audit
        self.wal_mode = wal_mode
        self._connection: Optional[sqlite3.Connection] = None
        
        # Garantir que o diretório existe
        self.db_path.parent.mkdir(parents=True, exist_ok=True)
        
        # Configurações de segurança do arquivo
        if os.name != 'nt':  # Unix-like systems
            os.chmod(self.db_path, 0o600)  # Apenas owner pode ler/escrever
        
        logger.info(
            "DatabaseService inicializado",
            extra={
                "db_path": str(db_path),
                "wal_mode": wal_mode,
                "audit_enabled": enable_audit
            }
        )
    
    def _derive_key(self, password: str, salt: Optional[bytes] = None) -> Tuple[bytes, bytes]:
        """
        Deriva chave de criptografia usando PBKDF2.
        
        Conforme ISO 27001 A.10.1.1 - Política de controle de acesso
        
        Args:
            password: Senha do usuário
            salt: Salt opcional (gerado se não fornecido)
            
        Returns:
            Tupla (key, salt)
        """
        if salt is None:
            salt = os.urandom(SALT_LENGTH)
        
        kdf = PBKDF2HMAC(
            algorithm=hashes.SHA512(),
            length=KEY_LENGTH,
            salt=salt,
            iterations=PBKDF2_ITERATIONS,
            backend=default_backend()
        )
        
        key = kdf.derive(password.encode('utf-8'))
        return key, salt
    
    def connect(self) -> None:
        """
        Estabelece conexão com o banco de dados criptografado.
        
        Raises:
            DatabaseConnectionError: Se a conexão falhar
        """
        try:
            # Conectar ao SQLite
            self._connection = sqlite3.connect(
                str(self.db_path),
                check_same_thread=False,  # Permitir acesso de múltiplas threads
                timeout=30  # Timeout de 30 segundos
            )
            
            # Habilitar extensões
            self._connection.enable_load_extension(True)
            
            # Configurar SQLCipher
            self._connection.execute(f"PRAGMA key = '{self.encryption_key}'")
            
            # Aplicar configurações de criptografia
            for key, value in CIPHER_CONFIG.items():
                self._connection.execute(f"PRAGMA {key} = '{value}'")
            
            # Configurar WAL mode para melhor performance
            if self.wal_mode:
                self._connection.execute(f"PRAGMA journal_mode = {WAL_MODE}")
            
            # Configurar outras PRAGMAs importantes
            self._connection.execute("PRAGMA foreign_keys = ON")
            self._connection.execute("PRAGMA synchronous = NORMAL")  # Balance performance/security
            self._connection.execute("PRAGMA temp_store = MEMORY")
            
            # Habilitar FTS5 e JSON1
            self._connection.execute("PRAGMA enable_fts5 = 1")
            
            # Verificar se a chave está correta
            cursor = self._connection.execute("SELECT count(*) FROM sqlite_master")
            cursor.fetchone()
            
            logger.info(
                "Conexão estabelecida com sucesso",
                extra={
                    "db_path": str(self.db_path),
                    "cipher": CIPHER_CONFIG["cipher"]
                }
            )
            
        except sqlite3.DatabaseError as e:
            error_msg = f"Falha ao conectar ao banco de dados: {str(e)}"
            logger.error(error_msg, extra={"error": str(e)})
            raise DatabaseConnectionError(error_msg) from e
    
    def disconnect(self) -> None:
        """Fecha a conexão com o banco de dados."""
        if self._connection:
            try:
                # Forçar checkpoint do WAL antes de fechar
                if self.wal_mode:
                    self._connection.execute("PRAGMA wal_checkpoint(TRUNCATE)")
                
                self._connection.close()
                logger.info("Conexão fechada com sucesso")
            except sqlite3.Error as e:
                logger.error(f"Erro ao fechar conexão: {str(e)}")
            finally:
                self._connection = None
    
    @contextmanager
    def get_connection(self) -> Generator[sqlite3.Connection, None, None]:
        """
        Context manager para acesso thread-safe à conexão.
        
        Yields:
            sqlite3.Connection: Conexão ativa
            
        Raises:
            DatabaseConnectionError: Se não houver conexão ativa
        """
        if not self._connection:
            raise DatabaseConnectionError("Conexão não estabelecida. Chame connect() primeiro.")
        
        try:
            yield self._connection
        except sqlite3.Error as e:
            logger.error(f"Erro na operação do banco: {str(e)}")
            raise DatabaseError(f"Erro na operação: {str(e)}") from e
    
    def execute_query(
        self,
        query: str,
        params: Optional[Tuple] = None,
        fetch: bool = False
    ) -> Optional[List[Dict[str, Any]]]:
        """
        Executa uma query SQL com parâmetros.
        
        Args:
            query: Query SQL
            params: Parâmetros da query
            fetch: Se True, retorna resultados
            
        Returns:
            Lista de dicionários com resultados ou None
            
        Raises:
            DatabaseError: Se a execução falhar
        """
        with self.get_connection() as conn:
            try:
                cursor = conn.execute(query, params or ())
                
                if fetch:
                    columns = [description[0] for description in cursor.description]
                    results = [dict(zip(columns, row)) for row in cursor.fetchall()]
                    
                    if self.enable_audit:
                        self._log_audit("SELECT", query, params, len(results))
                    
                    return results
                
                conn.commit()
                
                if self.enable_audit:
                    self._log_audit("EXECUTE", query, params, cursor.rowcount)
                
                return None
                
            except sqlite3.Error as e:
                conn.rollback()
                error_msg = f"Erro ao executar query: {str(e)}"
                logger.error(error_msg, extra={"query": query, "params": params})
                raise DatabaseError(error_msg) from e
    
    def execute_many(
        self,
        query: str,
        params_list: List[Tuple]
    ) -> int:
        """
        Executa uma query SQL com múltiplos conjuntos de parâmetros.
        
        Args:
            query: Query SQL
            params_list: Lista de tuplas de parâmetros
            
        Returns:
            Número de linhas afetadas
            
        Raises:
            DatabaseError: Se a execução falhar
        """
        with self.get_connection() as conn:
            try:
                cursor = conn.executemany(query, params_list)
                conn.commit()
                
                if self.enable_audit:
                    self._log_audit("EXECUTE_MANY", query, None, cursor.rowcount)
                
                return cursor.rowcount
                
            except sqlite3.Error as e:
                conn.rollback()
                error_msg = f"Erro ao executar múltiplas queries: {str(e)}"
                logger.error(error_msg, extra={"query": query})
                raise DatabaseError(error_msg) from e
    
    def _log_audit(
        self,
        operation: str,
        query: str,
        params: Optional[Tuple],
        rows_affected: int
    ) -> None:
        """
        Registra operação no log de auditoria.
        
        Conforme ISO 27001 A.12.4.1 - Logging de eventos
        Conforme LGPD Art. 37 - Registro de operações
        """
        audit_entry = {
            "timestamp": datetime.utcnow().isoformat(),
            "operation": operation,
            "query": query[:200],  # Limitar tamanho do log
            "rows_affected": rows_affected,
            "user_id": None,  # Será preenchido pelo contexto de autenticação
            "session_id": None  # Será preenchido pelo contexto de sessão
        }
        
        # Log estruturado para auditoria
        logger.info(
            "AUDIT_LOG",
            extra={
                "audit_data": audit_entry,
                "event_type": "database_operation"
            }
        )
    
    def run_migrations(self, migrations_dir: Path) -> None:
        """
        Executa migrações de schema versionadas.
        
        Args:
            migrations_dir: Diretório contendo arquivos SQL de migração
            
        Raises:
            DatabaseMigrationError: Se a migração falhar
        """
        try:
            # Criar tabela de controle de versão
            self.execute_query("""
                CREATE TABLE IF NOT EXISTS schema_migrations (
                    version INTEGER PRIMARY KEY,
                    filename TEXT NOT NULL,
                    applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
                    checksum TEXT NOT NULL,
                    rolled_back_at TIMESTAMP
                )
            """)
            
            # Listar arquivos de migração ordenados
            migration_files = sorted(
                migrations_dir.glob("*.sql"),
                key=lambda f: int(f.stem.split('_')[0])
            )
            
            for migration_file in migration_files:
                version = int(migration_file.stem.split('_')[0])
                
                # Verificar se já foi aplicada
                existing = self.execute_query(
                    "SELECT version FROM schema_migrations WHERE version = ? AND rolled_back_at IS NULL",
                    (version,),
                    fetch=True
                )
                
                if existing:
                    logger.info(f"Migração {version} já aplicada, pulando")
                    continue
                
                # Ler e executar migração
                with open(migration_file, 'r', encoding='utf-8') as f:
                    sql = f.read()
                
                # Calcular checksum para integridade
                import hashlib
                checksum = hashlib.sha256(sql.encode()).hexdigest()
                
                # Executar em transação
                with self.get_connection() as conn:
                    try:
                        conn.executescript(sql)
                        
                        # Registrar migração
                        conn.execute(
                            """INSERT INTO schema_migrations (version, filename, checksum)
                               VALUES (?, ?, ?)""",
                            (version, migration_file.name, checksum)
                        )
                        
                        conn.commit()
                        
                        logger.info(
                            f"Migração {version} aplicada com sucesso",
                            extra={
                                "migration_file": migration_file.name,
                                "version": version,
                                "checksum": checksum[:16]
                            }
                        )
                        
                    except sqlite3.Error as e:
                        conn.rollback()
                        error_msg = f"Falha na migração {version}: {str(e)}"
                        logger.error(error_msg)
                        raise DatabaseMigrationError(error_msg) from e
                        
        except Exception as e:
            error_msg = f"Erro durante migrações: {str(e)}"
            logger.error(error_msg)
            raise DatabaseMigrationError(error_msg) from e
    
    def rollback_migration(self, version: int) -> None:
        """
        Reverte uma migração específica.
        
        Args:
            version: Versão da migração a reverter
            
        Raises:
            DatabaseMigrationError: Se o rollback falhar
        """
        try:
            # Verificar se a migração existe
            migration = self.execute_query(
                "SELECT * FROM schema_migrations WHERE version = ? AND rolled_back_at IS NULL",
                (version,),
                fetch=True
            )
            
            if not migration:
                raise DatabaseMigrationError(f"Migração {version} não encontrada ou já revertida")
            
            # Procurar script de rollback
            rollback_file = Path(f"migrations/{version:04d}_rollback.sql")
            if not rollback_file.exists():
                raise DatabaseMigrationError(f"Script de rollback para {version} não encontrado")
            
            # Executar rollback
            with open(rollback_file, 'r', encoding='utf-8') as f:
                sql = f.read()
            
            with self.get_connection() as conn:
                try:
                    conn.executescript(sql)
                    
                    # Marcar como revertida
                    conn.execute(
                        """UPDATE schema_migrations 
                           SET rolled_back_at = CURRENT_TIMESTAMP 
                           WHERE version = ?""",
                        (version,)
                    )
                    
                    conn.commit()
                    
                    logger.info(
                        f"Migração {version} revertida com sucesso",
                        extra={"version": version}
                    )
                    
                except sqlite3.Error as e:
                    conn.rollback()
                    raise DatabaseMigrationError(f"Falha no rollback {version}: {str(e)}") from e
                    
        except Exception as e:
            error_msg = f"Erro durante rollback: {str(e)}"
            logger.error(error_msg)
            raise DatabaseMigrationError(error_msg) from e
    
    def backup_database(self, backup_path: Path) -> None:
        """
        Cria backup do banco de dados.
        
        Conforme ISO 27001 A.12.3.1 - Backup de informações
        
        Args:
            backup_path: Caminho para salvar o backup
            
        Raises:
            DatabaseError: Se o backup falhar
        """
        try:
            # Fazer checkpoint do WAL
            if self.wal_mode:
                self.execute_query("PRAGMA wal_checkpoint(TRUNCATE)")
            
            # Copiar arquivo do banco
            import shutil
            shutil.copy2(self.db_path, backup_path)
            
            # Configurar permissões do backup
            if os.name != 'nt':
                os.chmod(backup_path, 0o600)
            
            logger.info(
                "Backup realizado com sucesso",
                extra={
                    "source": str(self.db_path),
                    "destination": str(backup_path),
                    "size": backup_path.stat().st_size
                }
            )
            
        except Exception as e:
            error_msg = f"Falha ao criar backup: {str(e)}"
            logger.error(error_msg)
            raise DatabaseError(error_msg) from e
    
    def restore_database(self, backup_path: Path) -> None:
        """
        Restaura banco de dados a partir de backup.
        
        Args:
            backup_path: Caminho do arquivo de backup
            
        Raises:
            DatabaseError: Se a restauração falhar
        """
        try:
            # Fechar conexão atual
            self.disconnect()
            
            # Verificar integridade do backup
            if not backup_path.exists():
                raise FileNotFoundError(f"Arquivo de backup não encontrado: {backup_path}")
            
            # Restaurar backup
            import shutil
            shutil.copy2(backup_path, self.db_path)
            
            # Configurar permissões
            if os.name != 'nt':
                os.chmod(self.db_path, 0o600)
            
            # Reconectar
            self.connect()
            
            logger.info(
                "Banco de dados restaurado com sucesso",
                extra={
                    "source": str(backup_path