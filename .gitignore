# =============================================================================
# .gitignore — Automação Jurídica Assistida
# Regras de exclusão para Python, Node.js, IDEs, variáveis de ambiente e builds
# =============================================================================

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribuição / Empacotamento
dist/
build/
*.egg-info/
*.egg
*.whl
sdist/
wheels/
pip-wheel-metadata/

# Ambientes virtuais
venv/
env/
.venv/
.env.local
.env.development
.env.staging
.env.production

# Instaladores
*.manifest
*.spec

# Pytest / Cobertura
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# MyPy
.mypy_cache/
dmypy.json
dmypy.txt

# Ruff / Linters
.ruff_cache/

# Celery
celerybeat-schedule
celerybeat.pid

# Alembic (arquivos temporários, não as migrações em si)
# As migrações em versions/ devem ser versionadas

# Logs
*.log
logs/

# -----------------------------------------------------------------------------
# Node.js / Frontend (React + Vite)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Builds do Vite
frontend/dist/
frontend/build/

# Cache do Vite e TypeScript
*.tsbuildinfo
.vite/

# Storybook (se utilizado)
storybook-static/

# ESLint
.eslintcache

# -----------------------------------------------------------------------------
# Variáveis de ambiente e segredos
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# Chaves e certificados
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks

# Tokens e credenciais
secrets/
*.secret

# -----------------------------------------------------------------------------
# IDEs e Editores
# -----------------------------------------------------------------------------

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# -----------------------------------------------------------------------------
# Sistemas Operacionais
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon\r
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# Volumes locais de desenvolvimento
docker-volumes/
data/

# -----------------------------------------------------------------------------
# Banco de dados local
# -----------------------------------------------------------------------------
*.sqlite3
*.db

# Dumps de banco
*.sql
!migrations/**/*.sql
!scripts/seed/*.sql

# -----------------------------------------------------------------------------
# Uploads e arquivos temporários
# -----------------------------------------------------------------------------
uploads/
tmp/
temp/
*.tmp

# Índices vetoriais locais (FAISS)
*.faiss
faiss_index/
vector_store/

# -----------------------------------------------------------------------------
# Documentação gerada
# -----------------------------------------------------------------------------
site/
docs/_build/

# -----------------------------------------------------------------------------
# Miscelânea
# -----------------------------------------------------------------------------
*.bak
*.orig
*.rej
.ipynb_checkpoints/
profile_default/
ipython_config.py
