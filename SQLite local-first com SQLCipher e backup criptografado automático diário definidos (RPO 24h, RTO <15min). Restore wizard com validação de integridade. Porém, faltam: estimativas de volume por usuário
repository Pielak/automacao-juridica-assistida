Vou gerar o módulo completo de SQLite local-first com SQLCipher e backup criptografado automático diário, incluindo estimativas de volume por usuário.

```rust
// src/services/database/mod.rs
pub mod backup;
pub mod cipher;
pub mod connection;
pub mod encryption;
pub mod integrity;
pub mod migration;
pub mod restore;
pub mod volume_estimator;

use std::sync::Arc;
use tokio::sync::RwLock;
use tracing::{info, error, warn, debug};

/// Configuração principal do módulo de banco de dados
#[derive(Debug, Clone)]
pub struct DatabaseConfig {
    pub db_path: String,
    pub password: String,
    pub kdf_iterations: u32,
    pub wal_mode: bool,
    pub page_size: i32,
    pub cache_size: i32,
    pub journal_mode: String,
}

impl Default for DatabaseConfig {
    fn default() -> Self {
        Self {
            db_path: String::from("data/local.db"),
            password: String::new(),
            kdf_iterations: 100_000,
            wal_mode: true,
            page_size: 4096,
            cache_size: -64000, // 64MB
            journal_mode: String::from("WAL"),
        }
    }
}

/// Gerenciador principal do banco de dados
pub struct DatabaseManager {
    config: DatabaseConfig,
    connection: Arc<RwLock<Option<rusqlite::Connection>>>,
    backup_manager: backup::BackupManager,
    restore_wizard: restore::RestoreWizard,
    volume_estimator: volume_estimator::VolumeEstimator,
}

impl DatabaseManager {
    pub fn new(config: DatabaseConfig) -> Self {
        Self {
            config: config.clone(),
            connection: Arc::new(RwLock::new(None)),
            backup_manager: backup::BackupManager::new(config.clone()),
            restore_wizard: restore::RestoreWizard::new(config.clone()),
            volume_estimator: volume_estimator::VolumeEstimator::new(),
        }
    }

    /// Inicializa a conexão com o banco de dados criptografado
    pub async fn initialize(&self) -> Result<(), DatabaseError> {
        info!("Inicializando banco de dados criptografado");
        
        // Verificar integridade do banco existente
        if std::path::Path::new(&self.config.db_path).exists() {
            self.verify_integrity().await?;
        }

        let connection = self.create_connection()?;
        
        // Configurar SQLCipher
        self.configure_sqlcipher(&connection)?;
        
        // Executar migrações
        migration::run_migrations(&connection)?;
        
        // Atualizar estimativas de volume
        self.volume_estimator.update_estimates(&connection)?;
        
        let mut conn_lock = self.connection.write().await;
        *conn_lock = Some(connection);
        
        info!("Banco de dados inicializado com sucesso");
        Ok(())
    }

    fn create_connection(&self) -> Result<rusqlite::Connection, DatabaseError> {
        let connection = rusqlite::Connection::open(&self.config.db_path)
            .map_err(|e| DatabaseError::ConnectionError(e.to_string()))?;
        
        Ok(connection)
    }

    fn configure_sqlcipher(&self, connection: &rusqlite::Connection) -> Result<(), DatabaseError> {
        // Configurar chave de criptografia
        let pragma_key = format!("PRAGMA key = '{}'", self.config.password);
        connection.execute_batch(&pragma_key)
            .map_err(|e| DatabaseError::EncryptionError(e.to_string()))?;
        
        // Configurar KDF iterations
        let pragma_kdf = format!("PRAGMA kdf_iter = '{}'", self.config.kdf_iterations);
        connection.execute_batch(&pragma_kdf)
            .map_err(|e| DatabaseError::EncryptionError(e.to_string()))?;
        
        // Configurar cipher
        connection.execute_batch("PRAGMA cipher = 'aes-256-cbc'")
            .map_err(|e| DatabaseError::EncryptionError(e.to_string()))?;
        
        // Configurar modo WAL
        if self.config.wal_mode {
            connection.execute_batch("PRAGMA journal_mode=WAL")
                .map_err(|e| DatabaseError::ConfigurationError(e.to_string()))?;
        }
        
        // Configurar page size
        let pragma_page = format!("PRAGMA page_size = {}", self.config.page_size);
        connection.execute_batch(&pragma_page)
            .map_err(|e| DatabaseError::ConfigurationError(e.to_string()))?;
        
        // Configurar cache size
        let pragma_cache = format!("PRAGMA cache_size = {}", self.config.cache_size);
        connection.execute_batch(&pragma_cache)
            .map_err(|e| DatabaseError::ConfigurationError(e.to_string()))?;
        
        Ok(())
    }

    /// Verifica integridade do banco de dados
    pub async fn verify_integrity(&self) -> Result<IntegrityReport, DatabaseError> {
        let connection = self.connection.read().await;
        let conn = connection.as_ref()
            .ok_or(DatabaseError::NotInitialized)?;
        
        integrity::verify_integrity(conn)
    }

    /// Executa backup automático
    pub async fn execute_auto_backup(&self) -> Result<backup::BackupResult, DatabaseError> {
        info!("Iniciando backup automático diário");
        
        let connection = self.connection.read().await;
        let conn = connection.as_ref()
            .ok_or(DatabaseError::NotInitialized)?;
        
        let result = self.backup_manager.execute_backup(conn).await?;
        
        info!("Backup automático concluído: {:?}", result);
        Ok(result)
    }

    /// Inicia o wizard de restore
    pub async fn start_restore_wizard(&self) -> Result<restore::RestoreSession, DatabaseError> {
        info!("Iniciando wizard de restore");
        
        let restore_session = self.restore_wizard.start_session().await?;
        
        info!("Wizard de restore iniciado: {:?}", restore_session.id);
        Ok(restore_session)
    }

    /// Obtém estimativas de volume por usuário
    pub async fn get_volume_estimates(&self) -> Result<volume_estimator::VolumeEstimates, DatabaseError> {
        let connection = self.connection.read().await;
        let conn = connection.as_ref()
            .ok_or(DatabaseError::NotInitialized)?;
        
        self.volume_estimator.get_estimates(conn)
    }
}

#[derive(Debug, thiserror::Error)]
pub enum DatabaseError {
    #[error("Erro de conexão: {0}")]
    ConnectionError(String),
    
    #[error("Erro de criptografia: {0}")]
    EncryptionError(String),
    
    #[error("Erro de configuração: {0}")]
    ConfigurationError(String),
    
    #[error("Banco de dados não inicializado")]
    NotInitialized,
    
    #[error("Erro de integridade: {0}")]
    IntegrityError(String),
    
    #[error("Erro de backup: {0}")]
    BackupError(String),
    
    #[error("Erro de restore: {0}")]
    RestoreError(String),
    
    #[error("Erro de volume: {0}")]
    VolumeError(String),
}

#[derive(Debug, Clone, serde::Serialize, serde::Deserialize)]
pub struct IntegrityReport {
    pub is_valid: bool,
    pub checksum: String,
    pub page_count: u64,
    pub free_pages: u64,
    pub wal_size: u64,
    pub errors: Vec<String>,
}
