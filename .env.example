# ==============================================================================
# Automação Jurídica Assistida — Variáveis de Ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha os valores adequados ao seu ambiente.
# NUNCA commite o arquivo .env no repositório.
# ==============================================================================

# ------------------------------------------------------------------------------
# Ambiente da Aplicação
# ------------------------------------------------------------------------------
APP_ENV=development
# Valores aceitos: development, staging, production

APP_NAME=automacao-juridica-assistida
APP_VERSION=0.1.0
APP_DEBUG=true
# Em produção, defina APP_DEBUG=false

APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
# Em produção, ajuste APP_WORKERS conforme núcleos disponíveis (ex: 4)

# Nível de log: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# ------------------------------------------------------------------------------
# Banco de Dados — PostgreSQL
# ------------------------------------------------------------------------------
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=automacao_juridica
DATABASE_USER=postgres
DATABASE_PASSWORD=troque_esta_senha_em_producao

# URL completa de conexão (asyncpg para operações assíncronas)
# Formato: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# URL síncrona para migrações Alembic
DATABASE_URL_SYNC=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# Pool de conexões
DATABASE_POOL_SIZE=10
DATABASE_POOL_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# ------------------------------------------------------------------------------
# Redis — Cache e Broker do Celery
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# DB separado para cache de sessões
REDIS_SESSION_DB=1
REDIS_SESSION_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_SESSION_DB}

# ------------------------------------------------------------------------------
# Autenticação — JWT
# ------------------------------------------------------------------------------
# Algoritmo recomendado: RS256 para produção, HS256 aceitável em desenvolvimento
JWT_ALGORITHM=RS256

# Para RS256: caminhos para chaves pública e privada
JWT_PRIVATE_KEY_PATH=./certs/private.pem
JWT_PUBLIC_KEY_PATH=./certs/public.pem

# Para HS256 (apenas desenvolvimento): segredo simétrico
# Gere com: openssl rand -hex 64
JWT_SECRET_KEY=troque_este_segredo_com_openssl_rand_hex_64

# Tempo de expiração dos tokens (em minutos)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_MINUTES=10080
# 10080 minutos = 7 dias

# Emissor e audiência do token
JWT_ISSUER=automacao-juridica-assistida
JWT_AUDIENCE=automacao-juridica-assistida

# ------------------------------------------------------------------------------
# MFA — Autenticação Multifator (TOTP)
# ------------------------------------------------------------------------------
MFA_ENABLED=true
MFA_ISSUER_NAME=Automacao Juridica
# Número de dígitos do código TOTP
MFA_TOTP_DIGITS=6
# Intervalo de validade do código em segundos
MFA_TOTP_INTERVAL=30

# ------------------------------------------------------------------------------
# Hashing de Senhas — bcrypt
# ------------------------------------------------------------------------------
# Rounds do bcrypt (12 é um bom equilíbrio segurança/performance)
BCRYPT_ROUNDS=12

# ------------------------------------------------------------------------------
# CORS — Origens Permitidas
# ------------------------------------------------------------------------------
# Separe múltiplas origens com vírgula
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Em produção, restrinja ao domínio real:
# CORS_ALLOWED_ORIGINS=https://app.seudominio.com.br

CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Request-ID

# ------------------------------------------------------------------------------
# API Anthropic (Claude) — Integração de IA
# ------------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-TROQUE_PELA_SUA_CHAVE
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.3

# Configurações de resiliência (tenacity)
ANTHROPIC_MAX_RETRIES=3
ANTHROPIC_RETRY_WAIT_SECONDS=2
ANTHROPIC_TIMEOUT_SECONDS=120

# Rate limiting para chamadas à API Anthropic (requisições por minuto)
ANTHROPIC_RATE_LIMIT_RPM=50

# ------------------------------------------------------------------------------
# Celery — Processamento Assíncrono de Tarefas
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/2
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/3
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=America/Sao_Paulo

# Concorrência do worker
CELERY_WORKER_CONCURRENCY=4
# Prefetch multiplier (1 para tarefas longas como análise de documentos)
CELERY_WORKER_PREFETCH_MULTIPLIER=1

# ------------------------------------------------------------------------------
# Upload de Arquivos
# ------------------------------------------------------------------------------
# Tamanho máximo de upload em bytes (50MB)
UPLOAD_MAX_FILE_SIZE=52428800
# Tipos MIME permitidos (documentos jurídicos)
UPLOAD_ALLOWED_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
# Diretório de armazenamento temporário
UPLOAD_TEMP_DIR=./tmp/uploads
# Diretório de armazenamento permanente
UPLOAD_STORAGE_DIR=./storage/documents

# ------------------------------------------------------------------------------
# Rate Limiting — slowapi
# ------------------------------------------------------------------------------
# Limite global padrão (requisições por minuto por IP)
RATE_LIMIT_DEFAULT=60/minute
# Limite para endpoints de autenticação (proteção contra brute force)
RATE_LIMIT_AUTH=10/minute
# Limite para endpoints de análise de IA
RATE_LIMIT_ANALYSIS=20/minute

# ------------------------------------------------------------------------------
# Segurança — Headers e CSP
# ------------------------------------------------------------------------------
# Content Security Policy (ajuste conforme necessidade)
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data:

# HSTS (em produção)
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ------------------------------------------------------------------------------
# Auditoria e Logs Estruturados (structlog)
# ------------------------------------------------------------------------------
# Formato de saída: json (produção) ou console (desenvolvimento)
LOG_FORMAT=console
# Habilitar log de auditoria para ações sensíveis (LGPD)
AUDIT_LOG_ENABLED=true
# Retenção de logs de auditoria em dias
AUDIT_LOG_RETENTION_DAYS=365

# ------------------------------------------------------------------------------
# Busca Vetorial — FAISS / Milvus
# TODO: Decisão pendente (G002 ADR) — escolher entre FAISS (local) ou Milvus (distribuído)
# ------------------------------------------------------------------------------
# VECTOR_STORE_TYPE=faiss
# VECTOR_STORE_INDEX_PATH=./storage/vector_index
# MILVUS_HOST=localhost
# MILVUS_PORT=19530
# MILVUS_COLLECTION=documentos_juridicos

# ------------------------------------------------------------------------------
# DataJud — Integração com API do Poder Judiciário
# TODO: Configurar credenciais de acesso à API DataJud quando disponíveis
# ------------------------------------------------------------------------------
# DATAJUD_API_BASE_URL=https://api-publica.datajud.cnj.jus.br
# DATAJUD_API_KEY=
# DATAJUD_TIMEOUT_SECONDS=30
# DATAJUD_MAX_RETRIES=3

# ------------------------------------------------------------------------------
# Frontend — Variáveis expostas ao Vite (prefixo VITE_)
# Estas variáveis são injetadas no build do frontend
# ------------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_APP_NAME=Automação Jurídica Assistida
VITE_ENABLE_MFA=true
VITE_MAX_UPLOAD_SIZE_MB=50
VITE_SENTRY_DSN=

# ------------------------------------------------------------------------------
# Monitoramento (opcional)
# ------------------------------------------------------------------------------
# Sentry — rastreamento de erros
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=${APP_ENV}

# Health check endpoint habilitado
HEALTH_CHECK_ENABLED=true

# ------------------------------------------------------------------------------
# Design Tokens (G005 ADR — PENDENTE)
# TODO: Definir tokens de design (cores, tipografia, breakpoints) após ADR G005
# ------------------------------------------------------------------------------
# VITE_THEME_PRIMARY_COLOR=#1a365d
# VITE_THEME_SECONDARY_COLOR=#2b6cb0
# VITE_THEME_FONT_FAMILY=Inter, sans-serif
