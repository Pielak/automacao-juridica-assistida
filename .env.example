# ==============================================================================
# Automação Jurídica Assistida — Variáveis de Ambiente
# ==============================================================================
# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env no repositório.
# ==============================================================================

# ------------------------------------------------------------------------------
# SQLCipher — Criptografia do banco de dados local
# ------------------------------------------------------------------------------
# Chave mestra para criptografia AES-256-CBC do SQLite via SQLCipher.
# Deve ter no mínimo 32 caracteres. Gere com:
#   openssl rand -base64 48
# ATENÇÃO: Se perder esta chave, os dados do banco serão irrecuperáveis.
SQLCIPHER_KEY=CHANGE_ME_USE_openssl_rand_base64_48

# Número de iterações PBKDF2 para derivação da chave (padrão: 100000)
# Valores maiores aumentam segurança mas tornam a abertura do banco mais lenta.
SQLCIPHER_PBKDF2_ITERATIONS=100000

# Caminho do arquivo de banco de dados SQLite/SQLCipher (relativo ao diretório de dados da app)
# Padrão: dados são armazenados no diretório de dados do Tauri (platform-specific)
SQLCIPHER_DB_PATH=automacao_juridica.db

# ------------------------------------------------------------------------------
# DataJud — API do Conselho Nacional de Justiça
# ------------------------------------------------------------------------------
# Chave de API para acesso ao DataJud (https://datajud-wiki.cnj.jus.br/)
# Solicite em: https://datajud-wiki.cnj.jus.br/api-publica/acesso
DATAJUD_API_KEY=CHANGE_ME_YOUR_DATAJUD_API_KEY

# URL base da API DataJud
DATAJUD_BASE_URL=https://api-publica.datajud.cnj.jus.br

# Timeout em segundos para requisições ao DataJud
DATAJUD_TIMEOUT_SECONDS=30

# Número máximo de tentativas (retry) para requisições ao DataJud
DATAJUD_MAX_RETRIES=3

# Backoff inicial em segundos entre retries (exponencial)
DATAJUD_RETRY_BACKOFF_SECONDS=1.0

# ------------------------------------------------------------------------------
# IA Local — Ollama / llama.cpp
# ------------------------------------------------------------------------------
# URL do servidor Ollama local
OLLAMA_URL=http://127.0.0.1:11434

# Modelo padrão para análise jurídica e chat
# Exemplos: llama3.1, mistral, sabia-2 (para português jurídico)
OLLAMA_MODEL=llama3.1

# Modelo alternativo para tarefas mais leves (sumarização, classificação)
# Deixe vazio para usar o mesmo modelo principal
OLLAMA_MODEL_LIGHT=

# Timeout em segundos para inferência (modelos grandes podem demorar)
OLLAMA_TIMEOUT_SECONDS=120

# Temperatura padrão para geração de texto (0.0 = determinístico, 1.0 = criativo)
# Para peças jurídicas, valores baixos (0.1-0.3) são recomendados
OLLAMA_TEMPERATURE=0.2

# Número máximo de tokens na resposta
OLLAMA_MAX_TOKENS=4096

# Tamanho da janela de contexto (depende do modelo e RAM disponível)
OLLAMA_CONTEXT_WINDOW=8192

# ------------------------------------------------------------------------------
# Pseudonimização — Proteção de dados pessoais
# ------------------------------------------------------------------------------
# Habilitar pseudonimização automática antes de enviar texto para IA
# DEVE ser true em produção para conformidade com LGPD/sigilo profissional
PSEUDONYMIZATION_ENABLED=true

# Seed para geração determinística de pseudônimos (permite reversão)
# Gere com: openssl rand -hex 32
PSEUDONYMIZATION_SEED=CHANGE_ME_USE_openssl_rand_hex_32

# ------------------------------------------------------------------------------
# Sidecar Python — Configuração do processo auxiliar
# ------------------------------------------------------------------------------
# Host e porta para comunicação IPC entre Tauri (Rust) e sidecar Python
SIDECAR_HOST=127.0.0.1
SIDECAR_PORT=9720

# Nível de log do sidecar Python: DEBUG, INFO, WARNING, ERROR, CRITICAL
SIDECAR_LOG_LEVEL=INFO

# Diretório para logs estruturados do sidecar
SIDECAR_LOG_DIR=logs

# ------------------------------------------------------------------------------
# Aplicação — Configurações gerais
# ------------------------------------------------------------------------------
# Ambiente: development, staging, production
APP_ENV=development

# Nível de log geral da aplicação Rust: trace, debug, info, warn, error
RUST_LOG=info

# Diretório para armazenamento de documentos gerados (peças jurídicas)
# Relativo ao diretório de dados da app. Arquivos são criptografados em repouso.
DOCUMENTS_STORAGE_DIR=documents

# Diretório para templates Jinja2 de peças jurídicas
TEMPLATES_DIR=templates

# ------------------------------------------------------------------------------
# Segurança — Autenticação local
# ------------------------------------------------------------------------------
# Algoritmo de hashing de senhas: argon2id (recomendado) ou bcrypt
PASSWORD_HASH_ALGORITHM=argon2id

# Tempo de expiração da sessão local em minutos
SESSION_TIMEOUT_MINUTES=60

# Número máximo de tentativas de login antes de bloqueio temporário
MAX_LOGIN_ATTEMPTS=5

# Tempo de bloqueio após exceder tentativas de login (em minutos)
LOCKOUT_DURATION_MINUTES=15

# ------------------------------------------------------------------------------
# Auditoria
# ------------------------------------------------------------------------------
# Habilitar log de auditoria detalhado (todas as operações CRUD)
AUDIT_LOG_ENABLED=true

# Retenção de logs de auditoria em dias (0 = sem limite)
AUDIT_LOG_RETENTION_DAYS=365
